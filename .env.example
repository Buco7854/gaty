# ─── Server ───────────────────────────────────────────────────────────────────
PORT=8080

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgres://gatie:gatie@localhost:5432/gatie?sslmode=disable

# ─── Cache (Valkey / Redis) ────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── MQTT Broker ──────────────────────────────────────────────────────────────
MQTT_BROKER=tcp://localhost:1883
MQTT_USERNAME=gatie-server   # must match ACL "user" rule
# MQTT_PASSWORD=             # optional, used by server to connect to broker
# MQTT_BROKER_AUTH: "true" = broker validates gate credentials via /api/mqtt/auth webhook (EMQX).
#                   unset/false = app-level token validation in each MQTT payload (Mosquitto).
MQTT_BROKER_AUTH=true

# ─── Public URLs ──────────────────────────────────────────────────────────────
# BASE_URL is the public HTTPS URL of this API (used for SSO callbacks, cookie Secure flag).
# CookieSecure is automatically set to true when BASE_URL starts with https://.
BASE_URL=https://api.example.com
FRONTEND_URL=https://app.example.com

# CORS_ORIGINS: comma-separated list of allowed frontend origins (no wildcard with credentials).
CORS_ORIGINS=https://app.example.com

# ─── JWT / Authentication ──────────────────────────────────────────────────────
# JWT_SECRET: HS256 signing secret — must be at least 32 characters.
# Generate a strong secret with: openssl rand -hex 32
JWT_SECRET=REPLACE_ME_WITH_A_STRONG_SECRET_AT_LEAST_32_CHARS

# AUTH_SESSION_DURATION: refresh token lifetime for platform users, in seconds.
# Set to 0 for infinite sessions. Default: 604800 (7 days).
# AUTH_SESSION_DURATION=604800

# ─── Password Policy ──────────────────────────────────────────────────────────
# AUTH_PASSWORD_MIN_LENGTH: minimum password length (default 8, recommend 12+).
# AUTH_PASSWORD_MIN_LENGTH=8
# AUTH_PASSWORD_REQUIRE_UPPER=true
# AUTH_PASSWORD_REQUIRE_LOWER=true
# AUTH_PASSWORD_REQUIRE_DIGIT=true

# ─── PIN / Gate Unlock ────────────────────────────────────────────────────────
# PIN_MAX_ATTEMPTS: failed unlock attempts allowed per IP per 15-min window (default 5).
# PIN_MAX_ATTEMPTS=5

# PIN_GATE_MAX_ATTEMPTS: failed unlock attempts allowed per gate per 15-min window (default 50).
# PIN_GATE_MAX_ATTEMPTS=50

# ─── HTTP Gate Driver ─────────────────────────────────────────────────────────
# HTTP_DRIVER_ALLOWED_CIDRS: comma-separated CIDRs or IPs exempt from the SSRF private-IP block.
# Use when gate devices live on an RFC-1918 LAN (e.g. "192.168.1.0/24,10.0.0.50").
# Bare IPs are treated as /32. Leave empty to block all private ranges (recommended for cloud).
# HTTP_DRIVER_ALLOWED_CIDRS=

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=8080

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgres://gatie:gatie@localhost:5432/gatie?sslmode=disable

# ─── Cache (Valkey / Redis) ────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── MQTT Broker ──────────────────────────────────────────────────────────────
MQTT_BROKER=tcp://localhost:1883
MQTT_USERNAME=   # optional, leave empty for anonymous (dev)
MQTT_PASSWORD=   # optional

# ─── Public URLs ──────────────────────────────────────────────────────────────
# BASE_URL is the public HTTPS URL of this API (used for SSO callbacks, cookie Secure flag).
# CookieSecure is automatically set to true when BASE_URL starts with https://.
BASE_URL=https://api.example.com
FRONTEND_URL=https://app.example.com

# CORS_ORIGINS: comma-separated list of allowed frontend origins (no wildcard with credentials).
CORS_ORIGINS=https://app.example.com

# ─── JWT / Authentication ──────────────────────────────────────────────────────
# JWT_SECRET: HS256 signing secret — must be at least 32 characters.
# Generate a strong secret with: openssl rand -hex 32
JWT_SECRET=REPLACE_ME_WITH_A_STRONG_SECRET_AT_LEAST_32_CHARS

# AUTH_ACCESS_TOKEN_TTL: access token lifetime in seconds (default 900 = 15 min).
# Lower values reduce the exposure window of stolen tokens.
# AUTH_ACCESS_TOKEN_TTL=900

# AUTH_SESSION_DURATION: refresh token lifetime for platform users, in seconds.
# Set to 0 for infinite sessions. Default: 604800 (7 days).
# AUTH_SESSION_DURATION=604800

# AUTH_BCRYPT_COST: bcrypt work factor for password hashing (default 12).
# Valid range: 4–31. Each increment roughly doubles hashing time.
# Increase to 13–14 on production hardware to slow brute-force attacks.
# AUTH_BCRYPT_COST=12

# ─── Password Policy ──────────────────────────────────────────────────────────
# AUTH_PASSWORD_MIN_LENGTH: minimum password length (default 8, recommend 12+).
# AUTH_PASSWORD_MIN_LENGTH=8
# AUTH_PASSWORD_REQUIRE_UPPER=true
# AUTH_PASSWORD_REQUIRE_LOWER=true
# AUTH_PASSWORD_REQUIRE_DIGIT=true

# ─── PIN / Gate Unlock ────────────────────────────────────────────────────────
# PIN_MIN_LENGTH: minimum digit count for numeric PIN codes (default 4, recommend 6+).
# PIN_MIN_LENGTH=4

# PIN_MAX_ATTEMPTS: failed unlock attempts allowed per IP per window (default 5).
# PIN_MAX_ATTEMPTS=5

# PIN_GATE_MAX_ATTEMPTS: failed unlock attempts allowed per gate per window (default 50).
# PIN_GATE_MAX_ATTEMPTS=50

# PIN_RATE_LIMIT_WINDOW: rate-limit sliding window in seconds (default 900 = 15 min).
# PIN_RATE_LIMIT_WINDOW=900

# PIN_MIN_UNLOCK_MS: minimum response time for unlock endpoints in milliseconds (default 400).
# Prevents timing attacks. Keep at 400 or higher.
# PIN_MIN_UNLOCK_MS=400

# ─── SSE (Server-Sent Events) ─────────────────────────────────────────────────
# SSE_TICKET_TTL: one-time SSE ticket lifetime in seconds (default 30).
# Shorter values reduce the window for ticket theft.
# SSE_TICKET_TTL=30

# ─── Tenant Domain Cache ──────────────────────────────────────────────────────
# TENANT_CACHE_TTL: Redis TTL for verified custom domain entries, in seconds (default 300 = 5 min).
# TENANT_CACHE_TTL=300

# TENANT_CACHE_NOT_FOUND_TTL: Redis TTL for negative domain lookup results, in seconds (default 30).
# TENANT_CACHE_NOT_FOUND_TTL=30

# ─── HTTP Gate Driver & Webhook ───────────────────────────────────────────────
# HTTP_DRIVER_DIAL_TIMEOUT_MS: TCP connect + TLS timeout for outbound gate HTTP calls, in ms (default 5000).
# HTTP_DRIVER_DIAL_TIMEOUT_MS=5000

# HTTP_DRIVER_RESPONSE_TIMEOUT_MS: response header timeout for outbound gate HTTP calls, in ms (default 10000).
# HTTP_DRIVER_RESPONSE_TIMEOUT_MS=10000

# WEBHOOK_MAX_RETRIES: retry attempts for HTTP_WEBHOOK status polls (default 3).
# WEBHOOK_MAX_RETRIES=3

# WEBHOOK_RETRY_DELAY_MS: delay between webhook poll retries in milliseconds (default 1000).
# WEBHOOK_RETRY_DELAY_MS=1000
